{
  "name": "train-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "prepare": "husky install",
    "test:redis": "tsx scripts/test-redis.ts",
    "test:postgres": "tsx scripts/test-postgres.ts",
    "test:email": "tsx scripts/test-email.ts",
    "test:all": "npm run test:redis && npm run test:postgres && npm run test:email",
    "test:s3": "tsx scripts/test-s3.ts",
    "upload:test": "tsx scripts/test-upload.ts",
    "seed": "tsx scripts/seed-database.ts",
    "seed:history": "tsx scripts/seed-history.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force",
    "worker": "tsx worker/index.ts",
    "worker:dev": "tsx watch worker/index.ts",
    "test:worker": "tsx scripts/test-worker.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run worker:dev\"",
    "create-admin": "tsx scripts/create-admin.ts",
    "postinstall": "husky install"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.515.0",
    "@aws-sdk/s3-request-presigner": "^3.515.0",
    "@prisma/client": "^5.9.1",
    "bcryptjs": "^2.4.3",
    "cookie": "^0.6.0",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.34.2",
    "fuse.js": "^7.1.0",
    "http-status-codes": "^2.3.0",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "sharp": "^0.33.2",
    "uuid": "^13.0.0",
    "@aws-sdk/client-ses": "^3.515.0",
    "@sendgrid/mail": "^8.1.3",
    "react-email": "^0.0.16",
    "@react-email/components": "^0.0.16"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^17.8.1",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie": "^0.6.0",
    "@types/ioredis": "^4.28.10",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.19.33",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "commitlint": "^17.8.1",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.1",
    "eslint-config-next": "^13.5.11",
    "eslint-config-prettier": "^9.1.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "husky": "^8.0.3",
    "lint-staged": "^14.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^5.9.1",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.9.3"
  }
}
