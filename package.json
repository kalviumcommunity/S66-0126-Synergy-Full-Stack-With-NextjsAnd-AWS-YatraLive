{
  "name": "train-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "prepare": "husky install",
    "test:redis": "tsx scripts/test-redis.ts",
    "seed": "tsx scripts/seed-database.ts",
    "worker": "tsx worker/index.ts",
    "worker:dev": "tsx watch worker/index.ts",
    "test:worker": "tsx scripts/test-worker.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run worker:dev\"",
    "postinstall": "husky install"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "http-status-codes": "^2.3.0",
    "ioredis": "^5.9.2",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/ioredis": "4.28.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "9.0.8",
    "tailwindcss": "^4",
    "typescript": "^5",
    "eslint": "^8",
    "eslint-config-prettier": "^9",
    "eslint-config-next": "^13",
    "@typescript-eslint/eslint-plugin": "^7",
    "@typescript-eslint/parser": "^7",
    "eslint-plugin-import": "^2",
    "eslint-plugin-react-hooks": "^4",
    "eslint-plugin-tailwindcss": "^3",
    "prettier": "^3",
    "prettier-plugin-tailwindcss": "^0.3",
    "husky": "^8",
    "lint-staged": "^14",
    "commitlint": "^17",
    "@commitlint/config-conventional": "^17",
    "concurrently": "8.2.2",
    "tsx": "4.7.0"
  }
}