generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model JourneyHistory {
  id                String   @id @default(uuid())
  trainId           String   @map("train_id")
  trainNumber       String   @map("train_number")
  trainName         String   @map("train_name")
  source            String
  destination       String
  route             Json
  scheduledDate     DateTime @map("scheduled_date")
  scheduledTime     String   @map("scheduled_time")
  actualTime        String?  @map("actual_time")
  delayMinutes      Int      @map("delay_minutes") @default(0)
  status            String   @default("ON_TIME")
  completedStations Json?    @map("completed_stations")
  finalStationIndex Int?     @map("final_station_index")
  createdAt         DateTime @map("created_at") @default(now())
  updatedAt         DateTime @map("updated_at") @updatedAt

  @@index([trainId])
  @@index([trainNumber])
  @@index([scheduledDate])
  @@index([status])
  @@index([delayMinutes])
  @@map("journey_history")
}

model DelayPattern {
  id           String   @id @default(uuid())
  stationCode  String   @map("station_code")
  trainNumber  String   @map("train_number")
  averageDelay Float    @map("average_delay")
  maxDelay     Int      @map("max_delay")
  totalJourneys Int     @map("total_journeys")
  delayedCount Int      @map("delayed_count")
  hourOfDay    Int?     @map("hour_of_day")
  dayOfWeek    Int?     @map("day_of_week")
  updatedAt    DateTime @map("updated_at") @updatedAt

  @@unique([stationCode, trainNumber, hourOfDay, dayOfWeek])
  @@index([stationCode])
  @@index([trainNumber])
  @@map("delay_patterns")
}

model AuditLog {
  id         String   @id @default(uuid())
  adminId    String?  @map("admin_id")
  admin      Admin?   @relation(fields: [adminId], references: [id])
  adminEmail String?  @map("admin_email")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  beforeState Json?   @map("before_state")
  afterState  Json?   @map("after_state")
  metadata    Json?
  createdAt   DateTime @map("created_at") @default(now())

  @@index([adminId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model SystemEvent {
  id        String   @id @default(uuid())
  type      String
  level     String   @default("INFO")
  source    String
  message   String
  details   Json?
  createdAt DateTime @map("created_at") @default(now())

  @@index([type])
  @@index([level])
  @@index([createdAt])
  @@map("system_events")
}

// ==============================================
// ADMIN USER MANAGEMENT
// ==============================================
// Secure storage for admin credentials and roles
// Like the official staff registry with photos and badges
model Admin {
  id                String    @id @default(uuid())
  // Basic info
  email             String    @unique
  password          String    // bcrypt hash
  name              String
  // Role-based access
  role              String    @default("admin") // "superadmin", "admin", "viewer"
  // Security
  twoFactorEnabled  Boolean   @default(false) @map("two_factor_enabled")
  twoFactorSecret   String?   @map("two_factor_secret")
  // Session tracking
  lastLogin         DateTime? @map("last_login")
  lastLoginIp       String?   @map("last_login_ip")
  loginCount        Int       @default(0) @map("login_count")
  // Account status
  isActive          Boolean   @default(true) @map("is_active")
  lockedUntil       DateTime? @map("locked_until")
  failedAttempts    Int       @default(0) @map("failed_attempts")
  // Metadata
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  createdBy         String?   @map("created_by") // Which admin created this
  // Relationships
  sessions          AdminSession[]
  auditLogs         AuditLog[]
  trainPhotos       TrainPhoto[]

  @@map("admins")
}

// ==============================================
// ADMIN SESSIONS - Track active sessions
// ==============================================
// Like sign-in/sign-out logs at the security desk
model AdminSession {
  id            String    @id @default(uuid())
  adminId       String    @map("admin_id")
  admin         Admin     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  // Session tokens
  refreshToken  String    @unique @map("refresh_token")
  accessToken   String?   @map("access_token") // Last known access token
  // Session info
  userAgent     String?
  ipAddress     String?   @map("ip_address")
  location      String?   // Approximate location from IP
  // Expiry
  expiresAt     DateTime  @map("expires_at")
  // Metadata
  createdAt     DateTime  @default(now()) @map("created_at")
  lastUsedAt    DateTime  @updatedAt @map("last_used_at")
  revokedAt     DateTime? @map("revoked_at")

  @@index([adminId])
  @@index([refreshToken])
  @@index([expiresAt])
  @@map("admin_sessions")
}


// ==============================================
// TRAIN PHOTOS - Visual documentation
// ==============================================
// Photos uploaded by admins for each train
// Like having a photo album for every locomotive
model TrainPhoto {
  id            String   @id @default(uuid())
  
  // Which train
  trainId       String   @map("train_id")
  trainNumber   String   @map("train_number")
  
  // Photo metadata
  url           String   // Full S3 URL
  thumbnailUrl  String?  @map("thumbnail_url") // Optimized version
  key           String   // S3 object key (for deletion)
  
  // File info
  filename      String
  filesize      Int      // In bytes
  mimeType      String   @map("mime_type")
  width         Int?
  height        Int?
  
  // Photo details
  caption       String?
  location      String?  // Where photo was taken
  dateTaken     DateTime? @map("date_taken")
  
  // Who uploaded
  uploadedById  String   @map("uploaded_by_id")
  uploadedBy    Admin    @relation(fields: [uploadedById], references: [id])
  
  // Status
  isPrimary     Boolean  @default(false) @map("is_primary") // Main display photo
  isActive      Boolean  @default(true) @map("is_active")
  
  // Metadata
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  
  // Indexes
  @@index([trainId])
  @@index([trainNumber])
  @@index([uploadedById])
  @@index([isPrimary])
  
  @@map("train_photos")
}

// ==============================================
// EMAIL NOTIFICATIONS - Subscription Management
// ==============================================
// Track user preferences for email alerts
model EmailSubscription {
  id           String   @id @default(uuid())
  email        String   @unique
  
  // Subscription preferences
  isActive     Boolean  @default(true) @map("is_active")
  verificationToken String? @unique @map("verification_token")
  isVerified   Boolean  @default(false) @map("is_verified")
  verifiedAt   DateTime? @map("verified_at")
  
  // Unsubscribe tracking
  unsubscribeToken String? @unique @map("unsubscribe_token")
  unsubscribedAt   DateTime? @map("unsubscribed_at")
  
  // Notification preferences (JSON for flexibility)
  preferences  Json?
  
  // Metadata
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  
  @@index([isVerified])
  @@index([isActive])
  @@index([createdAt])
  @@map("email_subscriptions")
}

// ==============================================
// EMAIL LOGS - Delivery Tracking
// ==============================================
// Track all emails sent for auditing and debugging
model EmailLog {
  id           String   @id @default(uuid())
  to           String
  subject      String
  template     String   // "DELAY_ALERT", "PLATFORM_CHANGE", etc.
  
  // Trigger info
  trainId      String?  @map("train_id")
  trainNumber  String?  @map("train_number")
  delayMinutes Int?     @map("delay_minutes")
  platform     String?
  
  // Delivery status
  status       String   @default("PENDING") // "PENDING", "SENT", "FAILED", "BOUNCED"
  provider     String   // "AWS_SES", "SENDGRID"
  providerMessageId String? @map("provider_message_id")
  
  // Error tracking
  errorMessage String?  @map("error_message")
  errorCode    String?  @map("error_code")
  
  // Metadata
  sentAt       DateTime? @map("sent_at")
  createdAt    DateTime @default(now()) @map("created_at")
  
  @@index([to])
  @@index([status])
  @@index([trainId])
  @@index([sentAt])
  @@map("email_logs")
}