# ==============================================
# Train Tracker Environment Variables
# ==============================================

# Node
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Simulation
WORKER_UPDATE_INTERVAL=8
MAX_DELAY_MINUTES=30
DELAY_PROBABILITY=30
LOG_LEVEL=info
DEBUG=false

# Feature flags
ENABLE_ADMIN=true
ENABLE_FAVORITES=true

# PostgreSQL
POSTGRES_USER=train_tracker
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=train_tracker
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://train_tracker:your_secure_password@localhost:5432/train_tracker?schema=public

# PGAdmin (optional)
PGADMIN_EMAIL=admin@traintracker.com
PGADMIN_PASSWORD=admin123
